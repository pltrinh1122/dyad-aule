#!/usr/bin/env bash
# bin/_board — the Activity Board mirror engine (plan node N9; op-SoT, C2/C3).
#
# WHAT: projects the DERIVED plan-node state onto a GitHub view (one issue per node, columns as
#   board:<slug> labels; a Projects v2 board when a project-scoped token is present). The plan
#   (plan/<id>.md) stays the SINGLE WRITER OF RECORD — this is a one-way, level-triggered cache:
#   every sync recomputes the desired state from ground and reconciles, so a hand-edit is
#   corrected on the next run and the drift is SURFACED, never silently absorbed (the wu-wei
#   scar; concurrency-fsm-evaluation C2/C3). A view, never a second writer.
#
# WHY the split (fidelity): the reconciliation logic — including drift detection — is PURE and
#   fixture-tested (criteria/node-mirror.sh, no network). Live GitHub I/O is quarantined in `sync`,
#   the CI-only glue. So the fidelity-bearing part is grounded; the I/O is thin.
#
# SUBCOMMANDS:
#   manifest  [--ref R] [--in-progress "N1,N2"]              # nodes → desired mirror (PURE)
#   plan-ops  [--ref R] [--in-progress ids] [--current F]    # desired vs current issues → ops (PURE)
#   sync      [--ref R] [--dry-run]                          # CI glue: gather live state, apply
#
# Column derivation (precedence, highest first) — DERIVED from node state, never dragged-as-truth:
#   1 DONE                → done              (issue closed)
#   2 id ∈ in-progress    → in-progress       (an open PR carries this node's Node:<id> trailer; N8)
#   3 AWAITING-OPERATOR   → awaiting-operator  (lane=operator, disposition TODO — or PR awaiting merge)
#   4 READY               → ready             (the frontier)
#   5 BLOCKED             → blocked           (deps not DONE)
# WIP=1 is made visible: >1 node in-progress emits a surfaced SEAM line (not an error — a seam).
set -uo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRONTIER="$HERE/_frontier"

# --- column slug ↔ human display name (single source) ---
col_display() {
  case "$1" in
    done)              echo "Done" ;;
    in-progress)       echo "In Progress" ;;
    awaiting-operator) echo "Awaiting Operator" ;;
    ready)             echo "Ready" ;;
    blocked)           echo "Blocked" ;;
    *)                 echo "$1" ;;
  esac
}

# derived node STATE (from _frontier) + the in-progress set → column slug + open/closed
col_for() { # col_for <state> <id> <in_progress_csv>
  local state="$1" id="$2" ip=",$3,"
  case "$state" in DONE) echo "done no"; return ;; esac
  case "$ip" in *",$id,"*) echo "in-progress yes"; return ;; esac
  case "$state" in
    AWAITING-OPERATOR) echo "awaiting-operator yes" ;;
    READY)             echo "ready yes" ;;
    BLOCKED)           echo "blocked yes" ;;
    *)                 echo "blocked yes" ;;   # unknown → treat as not-ready, surfaced by state
  esac
}

# ---- args ----
REF="origin/main"; INPROG=""; CURRENT=""; DRYRUN=0
cmd="${1:-}"; [ $# -gt 0 ] && shift || true
while [ $# -gt 0 ]; do
  case "$1" in
    --ref)         REF="${2:?--ref needs a value}"; shift ;;
    --in-progress) INPROG="${2:-}"; shift ;;
    --current)     CURRENT="${2:?--current needs a file or -}"; shift ;;
    --dry-run)     DRYRUN=1 ;;
    *) echo "usage: _board {manifest|plan-ops|sync} [--ref R] [--in-progress ids] [--current F] [--dry-run]" >&2; exit 2 ;;
  esac
  shift
done
INPROG="$(printf '%s' "$INPROG" | tr -d ' ')"   # normalize "N1, N2" → "N1,N2"

# ---- manifest: nodes → desired mirror (PURE; reuses _frontier for state = DRY) ----
build_manifest() {
  local nwip=0 wiplist=""
  "$FRONTIER" --all --ref "$REF" | while IFS= read -r line; do
    case "$line" in "· "*) continue ;; esac       # skip _frontier's HEAD-fallback note
    id="$(printf '%s\n' "$line" | awk '{print $1}')"
    state="$(printf '%s\n' "$line" | awk '{print $2}')"
    title="${line#*:: }"
    read -r col open <<EOF
$(col_for "$state" "$id" "$INPROG")
EOF
    printf 'MIRROR %s col=%s open=%s :: %s\n' "$id" "$col" "$open" "$title"
  done
  # WIP=1 visibility — surfaced, computed separately (subshell above can't export counts).
  nwip=0
  for id in $(printf '%s' "$INPROG" | tr ',' ' '); do
    [ -n "$id" ] && { nwip=$((nwip+1)); wiplist="$wiplist $id"; }
  done
  [ "$nwip" -gt 1 ] && printf 'SEAM wip>1:%s (WIP=1 — a second In-Progress card is a surfaced seam)\n' "$wiplist"
}

# ---- plan-ops: desired (manifest) vs current issues → reconciliation ops (PURE) ----
# --current F: TSV of existing node-issues, one per line: <node>\t<number>\t<state>\t<label>
#   (state ∈ open|closed; label = the current board:<slug> or "-"). Default: no current issues.
build_ops() {
  local manifest curtsv
  manifest="$(build_manifest)"
  curtsv=""
  if [ -n "$CURRENT" ]; then
    if [ "$CURRENT" = "-" ]; then curtsv="$(cat)"; else curtsv="$(cat "$CURRENT")"; fi
  fi
  # index current by node
  cur_num()   { printf '%s\n' "$curtsv" | awk -F'\t' -v n="$1" '$1==n{print $2; exit}'; }
  cur_state() { printf '%s\n' "$curtsv" | awk -F'\t' -v n="$1" '$1==n{print $3; exit}'; }
  cur_label() { printf '%s\n' "$curtsv" | awk -F'\t' -v n="$1" '$1==n{print $4; exit}'; }

  # desired side
  printf '%s\n' "$manifest" | grep '^MIRROR ' | while IFS= read -r line; do
    id="$(printf '%s\n' "$line" | awk '{print $2}')"
    col="$(printf '%s\n' "$line" | awk '{sub(/^col=/,"",$3); print $3}')"
    open="$(printf '%s\n' "$line" | awk '{sub(/^open=/,"",$4); print $4}')"
    title="${line#*:: }"
    wantstate="open"; [ "$open" = "no" ] && wantstate="closed"
    wantlabel="board:$col"
    num="$(cur_num "$id")"
    if [ -z "$num" ]; then
      printf 'CREATE %s label=%s state=%s :: %s\n' "$id" "$wantlabel" "$wantstate" "$title"
      continue
    fi
    haslabel="$(cur_label "$id")"; hasstate="$(cur_state "$id")"
    [ "$haslabel" != "$wantlabel" ] && printf 'RELABEL %s #%s %s→%s\n' "$id" "$num" "${haslabel:--}" "$wantlabel"
    if [ "$hasstate" != "$wantstate" ]; then
      if [ "$wantstate" = "closed" ]; then
        printf 'CLOSE %s #%s (derived Done)\n' "$id" "$num"
      else
        # desired open but issue is closed → a hand-close of a non-Done node: reconcile + surface.
        printf 'REOPEN %s #%s (derived %s, not Done)\n' "$id" "$num" "$col"
        printf 'DRIFT %s #%s hand-closed but node is not Done (derived %s) — reopened\n' "$id" "$num" "$col"
      fi
    fi
  done

  # orphans: a current node-issue whose node no longer exists in the manifest (removed by replan).
  printf '%s\n' "$curtsv" | while IFS=$'\t' read -r node num _st _lab; do
    [ -z "$node" ] && continue
    printf '%s\n' "$manifest" | grep -q "^MIRROR $node " || \
      printf 'ORPHAN %s #%s node absent from plan — surface (do not auto-close a node the plan dropped)\n' "$node" "$num"
  done
}

# ---- sync: CI glue (live GitHub I/O). NOT exercised by criteria (needs network). ----
BODY_MARK='dyad-node'   # issues carry: <!-- dyad-node: N9 --> so sync can map issue→node
do_sync() {
  command -v gh >/dev/null 2>&1 || { echo "board: gh not found — sync needs gh (CI has it)." >&2; exit 127; }
  local ip current op

  # derive in-progress: open PRs whose commits carry a Node:<id> trailer (N8). Best-effort enrichment.
  ip=""
  for prnum in $(gh pr list --state open --json number -q '.[].number' 2>/dev/null); do
    for nid in $(gh pr view "$prnum" --json commits -q '.commits[].messageBody' 2>/dev/null \
                 | grep -oE '^Node: *[A-Za-z0-9_-]+' | sed 's/^Node: *//'); do
      ip="$ip,$nid"
    done
  done
  ip="${ip#,}"; INPROG="$(printf '%s' "$ip" | tr -d ' ')"

  # gather current node-issues as TSV via gh's embedded --jq (no external vendor; gh feature).
  current="$(gh issue list --state all --limit 200 \
      --json number,state,body,labels \
      --jq '.[] | select(.body|test("<!-- '"$BODY_MARK"': *[A-Za-z0-9_-]+ *-->"))
            | [ (.body|capture("<!-- '"$BODY_MARK"': *(?<n>[A-Za-z0-9_-]+)").n),
                (.number|tostring),
                (.state|ascii_downcase),
                ([.labels[].name] | map(select(startswith("board:"))) | (.[0] // "-")) ]
            | @tsv' 2>/dev/null || true)"

  op="$(CURRENT=- ; printf '%s' "$current" | build_ops)"
  echo "── board sync (ref=$REF, in-progress=[${INPROG:-none}]) ──"
  printf '%s\n' "$op"
  # WIP=1 seam + drift are already in $op as SEAM/DRIFT lines — surfaced above.

  if [ "$DRYRUN" = 1 ]; then echo "── dry-run: no GitHub mutations ──"; return 0; fi

  # apply (issue-mirror layer — default GITHUB_TOKEN suffices for issues).
  printf '%s\n' "$op" | while IFS= read -r line; do
    set -- $line
    case "$1" in
      CREATE)  apply_create "$line" ;;
      RELABEL) apply_label "$2" "${line##*→}" ;;
      CLOSE)   gh issue close "${3#\#}" >/dev/null 2>&1 || true ;;
      REOPEN)  gh issue reopen "${3#\#}" >/dev/null 2>&1 || true ;;
      DRIFT|SEAM|ORPHAN) : ;;   # surfaced in output; reconciliation already emitted as CLOSE/REOPEN/RELABEL
    esac
  done

  # Projects v2 board layer — dormant unless a project-scoped token is provisioned (Operator setup).
  if [ -n "${DYAD_PROJECT_TOKEN:-}" ] && [ -n "${DYAD_PROJECT_NUMBER:-}" ]; then
    echo "── board projection: project-scoped token present — set Status field per column ──"
    echo "   (Projects v2 GraphQL sync would run here; issue labels are the source of the column)"
  else
    echo "── board projection DORMANT: no DYAD_PROJECT_TOKEN/DYAD_PROJECT_NUMBER — issue-mirror only."
    echo "   Operator setup: add a repo secret DYAD_PROJECT_TOKEN (a PAT with 'project' scope) and"
    echo "   set DYAD_PROJECT_NUMBER to the board's number to light up the Projects v2 columns."
  fi
}

apply_create() { # CREATE <id> label=<lab> state=<st> :: <title>
  local line="$1" id lab st title body
  id="$(printf '%s\n' "$line" | awk '{print $2}')"
  lab="$(printf '%s\n' "$line" | awk '{sub(/^label=/,"",$3); print $3}')"
  st="$(printf '%s\n' "$line" | awk '{sub(/^state=/,"",$4); print $4}')"
  title="${line#*:: }"
  body="$(printf 'Projected from the plan (a view, never a writer). Truth: plan/%s.md — state is DERIVED.\n\n<!-- %s: %s -->' "$(printf '%s' "$id" | tr '[:upper:]' '[:lower:]')" "$BODY_MARK" "$id")"
  gh label create "$lab" --color ededed --force >/dev/null 2>&1 || true
  local num
  num="$(gh issue create --title "[$id] $title" --body "$body" --label "$lab" 2>/dev/null | grep -oE '[0-9]+$' || true)"
  [ "$st" = "closed" ] && [ -n "$num" ] && gh issue close "$num" >/dev/null 2>&1 || true
}
apply_label() { # <#num> <board:slug>
  local num="${1#\#}" lab="$2"
  gh label create "$lab" --color ededed --force >/dev/null 2>&1 || true
  gh issue edit "$num" --add-label "$lab" >/dev/null 2>&1 || true
  # strip other board:* labels so exactly one column label remains (single-column truth)
  for other in 'done' in-progress awaiting-operator ready blocked; do
    [ "board:$other" != "$lab" ] && gh issue edit "$num" --remove-label "board:$other" >/dev/null 2>&1 || true
  done
}

case "$cmd" in
  manifest) build_manifest ;;
  plan-ops) build_ops ;;
  sync)     do_sync ;;
  ""|-h|--help) sed -n '2,30p' "$0" >&2; exit 0 ;;
  *) echo "board: unknown subcommand '$cmd' (see: _board --help)" >&2; exit 2 ;;
esac
