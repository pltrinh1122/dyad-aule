#!/usr/bin/env bash
# bin/_frontier — derive the activity board from the plan-cache (post issues-as-home flip, N11/N16).
#
# WHY: nodes now live as GitHub issues (N11). Node state is the STORED status:* lane (N11 ruled it
#   stored, because re-derivation is expensive — C2's own bound — and guarded by the N14 FSM). This
#   tool reads the OFFLINE plan-cache (.dyad-state/plan-cache/<n>.md, N15 — the check-reachable
#   projection of the issue truth), so "what needs me?" is a fresh read with no network. It PRINTS;
#   acting on a node stays a disposition (auto-trigger ≠ auto-judgment).
#
# The actionable frontier = nodes awaiting the Operator: status:clarify (needs d-sense) and
# status:dispose (needs d-land). --all shows every cached node with its stored status.
#
# Usage:  bin/_frontier            # the actionable frontier
#         bin/_frontier --all      # every cached node
#         bin/_frontier --ref R    # read the cache at another ref (fixtures, CI)
set -uo pipefail

REF="origin/main"; ALL=0
while [ $# -gt 0 ]; do
  case "$1" in
    --all) ALL=1 ;;
    --ref) REF="${2:?--ref needs a value}"; shift ;;
    *) echo "usage: _frontier [--all] [--ref <ref>]" >&2; exit 2 ;;
  esac
  shift
done
CACHE=".dyad-state/plan-cache"

# CACHE-NODE lines at REF (the ratified projection); fall back to the working tree if REF is
# unresolvable here (fresh CI checkouts), with a visible note.
if git rev-parse --verify -q "$REF^{commit}" >/dev/null 2>&1; then
  SRC="$(for f in $(git ls-tree -r --name-only "$REF" -- "$CACHE" 2>/dev/null | grep '\.md$'); do git show "$REF:$f" 2>/dev/null; done | grep -E '^CACHE-NODE ' || true)"
else
  echo "· reading working-tree cache ($REF unresolvable here)"
  SRC="$(cat "$CACHE"/*.md 2>/dev/null | grep -E '^CACHE-NODE ' || true)"
fi

if ! printf '%s' "$SRC" | grep -q .; then
  echo "· no node-cache at $REF (run: bin/_cache sync-down)"
  exit 0
fi

printf '%s\n' "$SRC" | while IFS= read -r l; do
  id="$(printf '%s\n' "$l" | awk '{print $2}')"
  status="$(printf '%s\n' "$l" | awk '{sub(/^status=/,"",$3); print $3}')"
  title="${l#*:: }"
  case "$status" in clarify|dispose) act=1 ;; *) act=0 ;; esac
  if [ "$ALL" = 1 ] || [ "$act" = 1 ]; then
    printf '%-6s %-9s :: %s\n' "$id" "$status" "$title"
  fi
done
exit 0
