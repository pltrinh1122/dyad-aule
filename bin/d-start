#!/usr/bin/env bash
# bin/d-start — dyad-aule Start Session Discipline (the mechanism behind the `d-start` token).
#
# WHY: a fresh agent otherwise HAND-runs (or forgets) the checks that prove the dyad-rt runtime is
#   actually live, the baseline is clean, and memory is durable. Mechanizing them removes a per-session
#   trigger AND hand-error, and closes the self-certification gap this dyad hit head-on: after
#   `bin/claude` turns the native gate off, `d-start` CERTIFIES the replacement guard is really wired.
#   Pattern referenced from dyad-bond@bin/standup.sh (its Start Session Discipline); aule's own.
#
# WHAT IT DOES — grounds *real* only; never certifies *right* (the Operator's, sealed by the merge):
#   1. Runtime  — is the .githooks floor wired (core.hooksPath)?  [auto-repairs it, visibly — sanctioned]
#   2. Reconcile— get to a clean baseline (bin/_reconcile): fetch, push unbacked work, switch to a fresh
#                 main + delete merged branches — ONLY where git guarantees safety; dirty/unpushed work is
#                 surfaced, never touched. Covers the "we didn't leave/restart clean" gap.
#   3. Real     — run ./check (grounds every criteria/ file) and report the verdict.
#   4. Durable  — dirty/unbacked tree = ungrounded memory (op-durability seam), post-reconcile.
#   5. Sync     — local main vs origin.
#   It SURFACES every seam (auto-trigger ≠ auto-judgment). Its two sanctioned autonomous acts — repair
#   the hooksPath wiring, and the safe reconcile — are Operator dispositions (2026-07-07), reported loudly.
#
# Usage:  bin/d-start                       # startup self-diagnostic + safe reconcile (the `d-start` token)
#         DYAD_DSTART_DIAGNOSE_ONLY=1 bin/d-start   # side-effect-free: dry-run the reconcile, skip ./check
#                                                   #   (used by criteria/d-start.sh so it can't recurse/mutate)
set -uo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT" || exit 1
DIAG="${DYAD_DSTART_DIAGNOSE_ONLY:-0}"

warn=0
lines=()
add()  { lines+=("$1"); }
flag() { warn=1; }

# ── 1. Runtime (dyad-rt) wiring — the self-certification the launcher's safety envelope depends on ──
hp="$(git config --get core.hooksPath 2>/dev/null || true)"
if [ "$hp" != ".githooks" ] && [ -d .githooks ]; then
  if git config core.hooksPath .githooks 2>/dev/null; then
    add "Runtime  : ✓ core.hooksPath REPAIRED → .githooks (was '${hp:-unset}') — floor now live for this clone."
  else
    add "Runtime  : ⚠ core.hooksPath is '${hp:-unset}' and auto-set FAILED — run: git config core.hooksPath .githooks"; flag
  fi
else
  add "Runtime  : ✓ core.hooksPath=.githooks — the .githooks floor fires (even on raw git)."
fi
rt_missing=()
for s in bin/_dyad-rt bin/_reconcile .githooks/pre-commit .githooks/pre-push bin/git bin/gh; do
  [ -x "$s" ] || rt_missing+=("$s")
done
if ((${#rt_missing[@]})); then
  add "         ⚠ not executable/present: ${rt_missing[*]} — the guard cannot fully fire."; flag
fi

# ── 2. Reconcile to a clean baseline (safe-auto; bin/_reconcile owns the safety envelope) ──
if [ "$DIAG" = 1 ]; then rec="$(./bin/_reconcile --dry-run 2>&1)"; recrc=0
else                     rec="$(./bin/_reconcile 2>&1)";           recrc=$?; fi
add "Reconcile:"
while IFS= read -r rl; do [ -n "$rl" ] && add "         · $rl"; done <<<"$rec"
[ "$recrc" != 0 ] && flag

# ── 3. Real-half — ground every criteria/ file (the operator paid once; grounding is free after) ──
if [ "$DIAG" = 1 ]; then
  add "Real     : – ./check skipped (diagnose-only)."
elif out="$(./check 2>&1)"; then
  n="$(printf '%s\n' "$out" | grep -c '^PASS ')"
  add "Real     : ✓ ./check green ($n criteria files, 0 fail)."
else
  fails="$(printf '%s\n' "$out" | grep '^FAIL ' | awk '{print $2}' | paste -sd, - )"
  add "Real     : ⚠ ./check FAILED — do not trust the turn. Failing: ${fails:-?}. Run ./check for detail."; flag
fi

# ── 4. Durability seam (op-durability) — dirty/unbacked = ungrounded memory (post-reconcile) ──
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
dirty="$(git status --porcelain 2>/dev/null || true)"
unbacked="$(git rev-list --count HEAD --not --remotes 2>/dev/null || echo '?')"
if [ -n "$dirty" ]; then
  add "Durable  : ⚠ working tree DIRTY on '$branch' ($(printf '%s\n' "$dirty" | wc -l | tr -d ' ') paths) — commit before relying on the tree as memory."; flag
elif [ "$unbacked" != "0" ]; then
  add "Durable  : ⚠ $unbacked commit(s) on '$branch' not backed up on any remote — push so the remote holds the memory."; flag
else
  add "Durable  : ✓ clean + backed up on '$branch'."
fi
if [ "$branch" = "main" ]; then
  add "         · on main — read-only here; branch before mutating (op-durability): git switch -c <branch>."
fi
# op-provenance (plan node N8): unpushed commits must trace to a plan node — surfaced, not judged.
if [ "$unbacked" != "0" ] && [ "$unbacked" != "?" ] && [ -x bin/_dyad-rt ]; then
  untraced=0
  for c in $(git rev-list HEAD --not --remotes 2>/dev/null); do
    ./bin/_dyad-rt check-provenance "$c" >/dev/null 2>&1 || untraced=$((untraced+1))
  done
  if [ "$untraced" != 0 ]; then
    add "         ⚠ $untraced unpushed commit(s) lack Node: provenance (op-provenance) — amend before PR; the CI gate will refuse them."; flag
  fi
fi

# ── 5. Anchor sync (best-effort) — is local main behind origin? (reconcile already fetched if live) ──
if git rev-parse --verify -q origin/main >/dev/null 2>&1; then
  behind="$(git rev-list --count main..origin/main 2>/dev/null || echo 0)"
  if [ "$behind" != "0" ]; then
    add "Sync     : ⚠ local main is $behind behind origin/main — git pull --ff-only."; flag
  else
    add "Sync     : ✓ local main level with origin/main."
  fi
fi

# ── 6. Plan frontier (op-queue; plan node N1) — state derived from ground on every run, never
#      stored. SURFACED ONLY: picking a node stays a disposition (auto-trigger ≠ auto-judgment). ──
if [ -x bin/_frontier ]; then
  fr="$(./bin/_frontier 2>&1)"
  add "Plan     :"
  if [ -n "$fr" ]; then
    while IFS= read -r pl; do [ -n "$pl" ] && add "         · $pl"; done <<<"$fr"
  else
    add "         · frontier empty — no READY nodes (plan complete or all blocked)."
  fi
fi

# ── Output ──
printf '%s\n\n' "dyad-aule d-start — Start Session Discipline (real-half self-cert). Read DYAD.md; d-start grounds *real*, the merge is *right* (the Operator's)."
printf '%s\n' "${lines[@]}"
echo
if ((warn)); then
  echo "d-start: ⚠ seams surfaced above — disposition is yours (surfaced, not auto-judged)."
  exit 1
fi
echo "d-start: ✓ runtime live · baseline clean · real-half grounded · memory durable. Clear to work."
