#!/usr/bin/env bash
# bin/_dyad-rt — the Dyad Runtime enforcer (dyad-aule).
#
# WHAT: the single home for dyad-aule's runtime boundary policy. Every guard decision —
#   "may this git/gh mutation proceed?" — is answered here and NOWHERE else. The .githooks
#   floor and the bin/git · bin/gh wrappers are thin call sites; this file holds the rule
#   (O2 single-home / DRY). Change the boundary once, here.
#
# WHY (architecture — dyad-rt, adapted from dyad-cairn@DYAD.md §5, made aule's own):
#   - Execution Sandbox Invariant: the agent never calls raw git/gh; mutations route through
#     physical ./bin/ wrappers → through this enforcer. (cairn's shape.)
#   - Builder vs Enforcer Invariant: enforcement lives in a dedicated Enforcer script, never
#     baked into the tool that does the work. This IS that script. (cairn's shape.)
#   - aule's OWN boundary (not cairn's external-repo ABAC): op-durability / op-PR —
#     NEVER commit or push to `main`; main is the Operator's, and merge-to-main is the
#     Operator's canonical *right* judgment, never the agent's (DYAD.md). So: refuse any
#     mutation targeting main, and refuse `gh pr merge`.
#
# FIDELITY (aule's craft): a guard that is asserted but not wired is counterfeit — the exact
#   failure aule's own dialectic/ pins on peers. So this enforcer is proven *real* by
#   criteria/dyad-rt.sh, which drives it and asserts it both DENIES the forbidden mutations
#   AND ALLOWS a working-branch push (a guard that denies everything proves nothing).
#
# Subcommands (all exit 0 = allowed, nonzero = refused; refusals print a steering vector to stderr):
#   dyad-rt check-branch <branch>       # deny if <branch> is protected (commit target)
#   dyad-rt check-push  <remote-ref>    # deny if <remote-ref> targets protected (push/force/delete)
#   dyad-rt check-gh    <gh-args...>    # deny `gh pr merge` (merge-to-main is the Operator's)
#   dyad-rt protected                   # print the protected branch name (single source)
#   dyad-rt check-provenance <commit>   # op-provenance (plan node N8): deny an artifact-mutating
#                                       #   commit lacking a 'Node: <id>' trailer that resolves to
#                                       #   plan/. Class is DERIVED from paths, never declared:
#                                       #   only-.dyad-state/ = state capture (exempt); empty and
#                                       #   merge commits exempt. CI is the authoritative gate.
#   dyad-rt check-provenance-staged <msgfile>  # same rule at the commit-msg floor (early steering)
set -euo pipefail

# The one protected branch. main is the Operator's (op-durability / op-PR).
PROTECTED_BRANCH="${DYAD_RT_PROTECTED_BRANCH:-main}"

deny() {
  # deny "<what>" "<why>" "<escape/steering>"
  {
    echo "🚫 dyad-rt: $1"
    echo "   why: $2"
    echo "   → $3"
  } >&2
  exit 1
}

# Normalize a ref to its branch name. Handles "refs/heads/main" and "src:dst" refspecs, but
# preserves slashes IN the branch name (so "release/main" stays "release/main", NOT "main" —
# stripping to the last slash would false-positive on any branch ending in "/main").
_branch_of_ref() {
  local r="${1##*:}"      # "src:dst" refspec → the destination side
  echo "${r#refs/heads/}" # drop the refs/heads/ prefix if present
}

# Does node <id> exist? Since the issues-as-home flip (N11), a node id is a GitHub issue NUMBER
# ('#42'), resolved against the offline plan-cache (.dyad-state/plan-cache/<n>.md, N15) so the check
# stays check-reachable and network-free. Legacy 'Nk' ids (pre-migration history + in-flight
# migration commits) still resolve against plan/*.md while it exists. At ref $2 when given, else the
# working tree (the commit-msg floor resolves against the tree being committed).
_plan_has_node() {
  local id="$1" ref="${2:-}" f n
  case "$id" in
    \#[0-9]*)                                   # issue-number id → the plan-cache (state-capture)
      n="${id#\#}"
      if [ -n "$ref" ]; then git cat-file -e "$ref:.dyad-state/plan-cache/$n.md" 2>/dev/null
      else [ -f ".dyad-state/plan-cache/$n.md" ]; fi
      ;;
    *)                                          # legacy Nk id → plan/*.md while it exists
      {
        if [ -n "$ref" ]; then
          for f in $(git ls-tree -r --name-only "$ref" -- plan/ 2>/dev/null | grep '\.md$'); do
            git show "$ref:$f" 2>/dev/null
          done
        else
          cat plan/*.md 2>/dev/null
        fi
      } | awk -v id="$id" '$1=="NODE" && $2==id{found=1} END{exit !found}'
      ;;
  esac
}

# Extract the first 'Node: <id>' trailer from stdin; empty if none. Accepts the '#<issue>' form
# (issues-as-home) and the legacy bare id.
_node_trailer() { grep -E '^Node: *#?[A-Za-z0-9_-]+ *$' | head -1 | sed -e 's/^Node: *//' -e 's/ *$//'; }

# True (0) iff the path list on stdin contains at least one path OUTSIDE .dyad-state/ —
# i.e., the commit is an ARTIFACT mutation, not state capture (op-provenance carve-out).
_touches_artifacts() { grep -v '^$' | grep -qv '^\.dyad-state/'; }

cmd="${1:-}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
  protected)
    echo "$PROTECTED_BRANCH"
    ;;

  check-branch)
    branch="$(_branch_of_ref "${1:-}")"
    if [ "$branch" = "$PROTECTED_BRANCH" ]; then
      deny "commit on '$PROTECTED_BRANCH' refused" \
           "op-durability — never commit to main; work on a branch (DYAD.md)" \
           "switch to a working branch: git switch -c <branch>   (escape: git commit --no-verify)"
    fi
    ;;

  check-push)
    ref="$(_branch_of_ref "${1:-}")"
    if [ "$ref" = "$PROTECTED_BRANCH" ]; then
      deny "push to '$PROTECTED_BRANCH' refused" \
           "op-PR — main is the Operator's; open a PR and let the Operator merge (DYAD.md)" \
           "push your working branch instead: git push -u origin <branch>   (escape: git push --no-verify)"
    fi
    ;;

  check-gh)
    # Refuse merge-to-main; allow the rest (pr create/view/status, issue, auth, ...).
    if [ "${1:-}" = "pr" ] && [ "${2:-}" = "merge" ]; then
      deny "gh pr merge refused" \
           "op-PR — merge-to-main is the Operator's canonical *right* judgment, never the agent's (DYAD.md)" \
           "leave the PR for the Operator to merge; the agent proposes, the Operator disposes"
    fi
    ;;

  check-provenance)
    commit="${1:?check-provenance needs a commit}"
    # Merge commits are the Operator's ratification act (op-PR) — exempt.
    nparents="$(git rev-list --no-walk --parents "$commit" 2>/dev/null | awk '{print NF-1; exit}')"
    [ "${nparents:-0}" -gt 1 ] && exit 0
    paths="$(git show --name-only --format= "$commit" 2>/dev/null)"
    # Empty commits mutate no artifact; only-.dyad-state/ commits are state capture (Observe).
    printf '%s\n' "$paths" | _touches_artifacts || exit 0
    id="$(git log -1 --format=%B "$commit" 2>/dev/null | _node_trailer)"
    if [ -z "$id" ]; then
      deny "artifact commit ${commit:0:10} lacks provenance" \
           "op-provenance — no Act without ingested intent; artifact mutations trace to a plan node (DYAD.md)" \
           "add trailer 'Node: <id>' referencing plan/   (escape: --no-verify locally; the CI gate still holds)"
    fi
    if ! _plan_has_node "$id" "$commit"; then
      deny "commit ${commit:0:10} names unknown node '$id'" \
           "op-provenance — the trailer must resolve to a NODE in plan/ at that commit" \
           "enqueue the node first (replanning PR) or fix the trailer id"
    fi
    ;;

  check-provenance-staged)
    msgfile="${1:?check-provenance-staged needs the commit-msg file}"
    # A merge in progress is the Operator's lane (and its tree diff is not an agent Act).
    [ -f "$(git rev-parse --git-dir 2>/dev/null)/MERGE_HEAD" ] && exit 0
    paths="$(git diff --cached --name-only 2>/dev/null)"
    printf '%s\n' "$paths" | _touches_artifacts || exit 0
    id="$(_node_trailer <"$msgfile")"
    if [ -z "$id" ]; then
      deny "commit lacks provenance (artifact paths staged)" \
           "op-provenance — no Act without ingested intent (DYAD.md); state capture belongs under .dyad-state/" \
           "add trailer 'Node: <id>' referencing plan/   (escape: git commit --no-verify; the CI gate still holds)"
    fi
    if ! _plan_has_node "$id"; then
      deny "trailer names unknown node '$id'" \
           "op-provenance — the trailer must resolve to a NODE in plan/*.md" \
           "enqueue the node first (replanning PR) or fix the trailer id"
    fi
    ;;

  ""|-h|--help)
    sed -n '2,20p' "$0" >&2
    exit 0
    ;;

  *)
    echo "dyad-rt: unknown subcommand '$cmd' (see: dyad-rt --help)" >&2
    exit 2
    ;;
esac
