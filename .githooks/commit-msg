#!/usr/bin/env bash
# .githooks/commit-msg — dyad-rt floor for op-provenance (plan node N8): an artifact-mutating
# commit must carry a 'Node: <id>' trailer resolving to plan/. Commit class is DERIVED from the
# staged paths, never declared: touching only .dyad-state/ = state capture (exempt, the
# op-durability carve-out); merges and empty commits exempt. `--no-verify` is the visible local
# escape — the AUTHORITATIVE gate is CI on the PR (remote ground). Policy lives in bin/_dyad-rt
# (single home); this hook only delegates.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
root="$(cd "$here/.." && pwd)"
exec "$root/bin/_dyad-rt" check-provenance-staged "$1"
