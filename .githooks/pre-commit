#!/usr/bin/env bash
# .githooks/pre-commit — dyad-rt hard floor: refuse a commit on the protected branch.
#
# This fires even on RAW `git commit` (not just bin/git), because bin/claude wires
# core.hooksPath → .githooks on launch. It survives permission-gate-off (DYAD mode) —
# the floor bin/claude's safety envelope names. `git commit --no-verify` is the documented,
# VISIBLE escape. Policy is in bin/_dyad-rt (single home); this is just the call site.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
root="$(cd "$here/.." && pwd)"
branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")"
[ -n "$branch" ] && exec "$root/bin/_dyad-rt" check-branch "$branch"
